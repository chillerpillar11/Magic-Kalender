name: Update Magic Calendar

on:
  schedule:
    - cron: "0 6 * * *"   # Täglich um 06:00 Uhr CET
  workflow_dispatch:      # Manuelles Ausführen möglich

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          pip install requests beautifulsoup4 ics

      - name: Run calendar generator
        run: |
          python generate_calendar.py

      - name: Commit and push changes
        run: |
          git config --global user.name "github-actions"
          git config --global user.email "github-actions@github.com"
          git add magic.ics
          git commit -m "Update calendar" || echo "No changes to commit"
          git push
